# ---------------------------------------------------------------------
# PBC Erding - .htaccess
# Wird von Next.js Static Export mitkopiert, greift am Apache.
# ---------------------------------------------------------------------

# --- Security Headers ---------------------------------------------------
<IfModule mod_headers.c>
    # Verhindert MIME-Type-Sniffing
    Header set X-Content-Type-Options "nosniff"

    # Anti-Clickjacking
    Header set X-Frame-Options "SAMEORIGIN"

    # Referrer-Policy: nur Origin senden
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions-Policy: unnoetige Features deaktivieren
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"

    # Strict-Transport-Security (HTTPS enforcen, nur aktivieren wenn die Site sicher nur ueber HTTPS laeuft)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Content-Security-Policy
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' wss://pbc-relay.onrender.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"

    # Cross-Origin Policy
    Header set Cross-Origin-Opener-Policy "same-origin"
    Header set Cross-Origin-Resource-Policy "same-origin"

    # Entfernt den Server-Header (falls mod_headers das erlaubt)
    Header unset X-Powered-By
</IfModule>

# --- Komprimierung (gzip) ----------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# --- Cache-Control ------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML: kurz cachen, damit Aenderungen zeitnah sichtbar sind
    ExpiresByType text/html "access plus 5 minutes"

    # Assets mit Content-Hash von Next.js: lang cachen
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"

    # Bilder
    ExpiresByType image/png "access plus 6 months"
    ExpiresByType image/jpeg "access plus 6 months"
    ExpiresByType image/webp "access plus 6 months"
    ExpiresByType image/svg+xml "access plus 6 months"

    # Fonts
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# --- Sensible Dateien sperren ------------------------------------------
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "(package\.json|package-lock\.json|tsconfig\.json|next\.config\.ts|\.env.*|README\.md|CLAUDE\.md|Plan_Webredaktion\.md)$">
    Require all denied
</FilesMatch>

# --- Default Charset ---------------------------------------------------
AddDefaultCharset UTF-8

# --- Error Pages (statisch) --------------------------------------------
ErrorDocument 404 /404.html
